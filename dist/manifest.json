{
  "manifest_version": 3,
  "name": "Productivity Suite",
  "version": "1.0",
  "description": "Multi feature productivity extension",

  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "contextMenus",
    "downloads"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html"
  },

  "options_page": "options.html",

  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },

  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+P"
      },
      "description": "Open Popup"
    },
    "save-session": {
      "suggested_key": {
        "default": "Ctrl+Shift+S"
      },
      "description": "Save Session"
    }
  }
}